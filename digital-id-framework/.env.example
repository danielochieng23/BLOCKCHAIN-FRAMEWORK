# Blockchain Configuration
PRIVATE_KEY=your_private_key_here
SEPOLIA_URL=https://sepolia.infura.io/v3/your_infura_project_id
POLYGON_URL=https://polygon-mainnet.infura.io/v3/your_infura_project_id

# API Configuration
PORT=3000
NODE_ENV=development
API_SECRET_KEY=your_secret_key_here

# Database Configuration (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/digital_id

# IPFS Configuration (for distributed storage)
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# Zero-Knowledge Proof Configuration
ZKP_CIRCUIT_PATH=./circuits
ZKP_PROVING_KEY_PATH=./circuits/proving_key.json
ZKP_VERIFICATION_KEY_PATH=./circuits/verification_key.json