{
  "name": "digital-id-framework",
  "version": "1.0.0",
  "description": "Blockchain & Privacy-Preserving Digital ID Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "compile-contracts": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network localhost",
    "demo": "cd demo && npm start",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["blockchain", "digital-identity", "privacy", "zero-knowledge", "self-sovereign-identity"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.9.0",
    "@ethereum/ethereum-cryptography": "^2.1.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.3",
    "merkletreejs": "^0.3.11",
    "crypto-js": "^4.2.0",
    "axios": "^1.6.2",
    "@zk-kit/protocols": "^2.5.1",
    "libsodium-wrappers": "^0.7.13"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.1",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "hardhat": "^2.19.3",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1"
  }
}