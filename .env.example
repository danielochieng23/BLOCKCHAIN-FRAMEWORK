# Server Configuration
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:8545
PRIVATE_KEY=your-private-key-for-deployment

# Contract Addresses (set after deployment)
IDENTITY_REGISTRY_ADDRESS=
ZK_VERIFICATION_ADDRESS=
PRIVACY_CREDENTIALS_ADDRESS=

# Network URLs (for different environments)
GOERLI_URL=https://goerli.infura.io/v3/your-infura-key
SEPOLIA_URL=https://sepolia.infura.io/v3/your-infura-key
MAINNET_URL=https://mainnet.infura.io/v3/your-infura-key

# Etherscan (for contract verification)
ETHERSCAN_API_KEY=your-etherscan-api-key

# Admin Configuration
ADMIN_ADDRESSES=0xYourAdminAddress1,0xYourAdminAddress2

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database (if using external database)
DATABASE_URL=postgresql://username:password@localhost:5432/blockchain_identity
REDIS_URL=redis://localhost:6379

# File Storage (for IPFS or other decentralized storage)
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn-for-error-tracking
ANALYTICS_KEY=your-analytics-key